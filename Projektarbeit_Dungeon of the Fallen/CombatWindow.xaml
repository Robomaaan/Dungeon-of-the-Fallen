<Window x:Class="Projektarbeit_Dungeon_of_the_Fallen.CombatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚔ Kampf" Height="780" Width="960"
        Background="#060a10" Foreground="#e0e0e0"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Closing="CombatWindow_Closing">

    <Window.Resources>
        <!-- HP-Bar Style -->
        <Style x:Key="HpBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#111" CornerRadius="5"
                                BorderBrush="#333" BorderThickness="1">
                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left" CornerRadius="5"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Knopf-Style -->
        <Style x:Key="CombatButton" TargetType="Button">
            <Setter Property="Background" Value="#1a1a2a"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a4a"/>
                                <Setter Property="BorderBrush" Value="#FFE040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3a3a6a"/>
                                <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Header -->
            <RowDefinition Height="420"/>  <!-- Battle arena (größer) -->
            <RowDefinition Height="*"/>    <!-- Actions -->
            <RowDefinition Height="100"/>  <!-- Log -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#0c1220"
                BorderBrush="#1a2a40" BorderThickness="0,0,0,1">
            <TextBlock Text="⚔  K A M P F  ⚔"
                       FontSize="18" FontWeight="Bold" Foreground="#FFD700"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontFamily="Consolas"/>
        </Border>

        <!-- ═══ BATTLE ARENA ═══ -->
        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#050810" Offset="0"/>
                    <GradientStop Color="#0a0f1c" Offset="0.5"/>
                    <GradientStop Color="#080c15" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Background image -->
            <Image Source="/Assets/Backgrounds/background_combat_dungeon_01.png"
                   Stretch="UniformToFill" Opacity="0.35"/>

            <!-- Floor hint -->
            <Rectangle VerticalAlignment="Bottom" Height="50" Opacity="0.35">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1a1a3a" Offset="0"/>
                        <GradientStop Color="#2a2a5a" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Enemy stats: top-right -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="30,14,50,0" Width="250">
                <TextBlock Text="{Binding EnemyName, Mode=OneWay}"
                           FontSize="16" FontWeight="Bold" Foreground="#FF7777"
                           Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding EnemyHP, Mode=OneWay}" Maximum="{Binding EnemyMaxHP}"
                             Width="250" Style="{StaticResource HpBarStyle}"
                             Foreground="#FF4444"/>
                <TextBlock Foreground="#888" FontSize="12" Margin="0,2">
                    <Run Text="{Binding EnemyHP, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding EnemyMaxHP, Mode=OneWay}"/>
                    <Run Text=" LP · RK "/>
                    <Run Text="{Binding EnemyArmorClass, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="#b0b0b0" FontSize="11" TextWrapping="Wrap"
                           Text="{Binding EnemyWeapon, Mode=OneWay}"/>
            </StackPanel>

            <!-- Enemy sprite: top-right -->
            <Canvas x:Name="EnemySpriteCanvas"
                    Width="190" Height="260"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,80,40,0"/>

            <!-- Player stats: bottom-left -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="50,0,0,14" Width="250">
                <TextBlock Text="{Binding PlayerName, Mode=OneWay}"
                           FontSize="16" FontWeight="Bold" Foreground="#66BBFF"
                           Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding PlayerHP, Mode=OneWay}" Maximum="{Binding PlayerMaxHP}"
                             Width="250" Style="{StaticResource HpBarStyle}"
                             Foreground="#44CC66"/>
                <TextBlock Foreground="#888" FontSize="12" Margin="0,2">
                    <Run Text="{Binding PlayerHP, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding PlayerMaxHP, Mode=OneWay}"/>
                    <Run Text=" LP · RK "/>
                    <Run Text="{Binding PlayerArmorClass, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Foreground="#b0b0b0" FontSize="11" TextWrapping="Wrap"
                           Text="{Binding PlayerWeapon, Mode=OneWay}"/>
            </StackPanel>

            <!-- Player sprite: bottom-left -->
            <Canvas x:Name="PlayerSpriteCanvas"
                    Width="190" Height="260"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="40,0,0,70"/>

            <!-- ═══ DICE ARENA ═══
                 Canvas 680 px breit, zentriert.
                 PlayerDie: Canvas.Left=60  → center bei 120 → Kollision: +160px TranslateX
                 EnemyDie:  Canvas.Left=500 → center bei 560 → Kollision: -160px TranslateX
                 Kollisionspunkt: Mitte des Canvas = 340 px
            -->
            <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="680" Height="200"
                    IsHitTestVisible="False">

                <!-- Statuslabel oben -->
                <TextBlock x:Name="DiceLabel"
                           Canvas.Left="0" Canvas.Top="2"
                           Width="680" TextAlignment="Center"
                           FontSize="13" Foreground="#aaaaaa" FontFamily="Consolas"/>

                <!-- Spieler-Würfel (links) -->
                <Border x:Name="PlayerDieBorder"
                        Width="120" Height="120"
                        Canvas.Left="60" Canvas.Top="28"
                        Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0"
                        Visibility="Hidden">
                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="PlayerDiceScale" ScaleX="1" ScaleY="1"/>
                            <RotateTransform x:Name="PlayerDiceRotate" Angle="0"/>
                            <TranslateTransform x:Name="PlayerDiceTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Image x:Name="PlayerDiceImage"
                           Width="120" Height="120" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Gegner-Würfel (rechts) -->
                <Border x:Name="EnemyDieBorder"
                        Width="120" Height="120"
                        Canvas.Left="500" Canvas.Top="28"
                        Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0"
                        Visibility="Hidden">
                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="EnemyDiceScale" ScaleX="1" ScaleY="1"/>
                            <RotateTransform x:Name="EnemyDiceRotate" Angle="0"/>
                            <TranslateTransform x:Name="EnemyDiceTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Image x:Name="EnemyDiceImage"
                           Width="120" Height="120" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Ergebnis-Zeile -->
                <TextBlock x:Name="DiceResultLabel"
                           Canvas.Left="0" Canvas.Top="156"
                           Width="680" TextAlignment="Center"
                           FontSize="13" FontWeight="Bold" Foreground="#FFD700"
                           FontFamily="Consolas"/>

                <!-- Vergleichs-Zeile -->
                <TextBlock x:Name="DiceCompareLabel"
                           Canvas.Left="140" Canvas.Top="175"
                           Width="400" TextAlignment="Center"
                           FontSize="10" Foreground="#cccccc"
                           TextWrapping="Wrap" FontFamily="Consolas"/>
            </Canvas>
        </Grid>

        <!-- ═══ ACTION PANEL ═══ -->
        <Border Grid.Row="2" Background="#0c1220"
                BorderBrush="#1a2a40" BorderThickness="0,1,0,1">
            <Grid Margin="30,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding StatusMessage}"
                           FontSize="15" Foreground="#cccccc"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           FontStyle="Italic"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="⚔  ANGREIFEN"
                            Command="{Binding AttackCommand}"
                            Style="{StaticResource CombatButton}"
                            Margin="0,0,20,0"/>
                    <Button Content="{Binding SkillButtonText}"
                            ToolTip="{Binding SkillDescription}"
                            Command="{Binding UseSkillCommand}"
                            Style="{StaticResource CombatButton}"
                            Foreground="#8fe1ff" BorderBrush="#8fe1ff"
                            Margin="0,0,20,0"/>
                    <Button Content="{Binding PotionButtonText}"
                            Command="{Binding UsePotionCommand}"
                            Style="{StaticResource CombatButton}"
                            Foreground="#FF88FF" BorderBrush="#FF88FF"
                            Margin="0,0,20,0"/>
                    <Button x:Name="CloseButton" Content="✕  SCHLIEẞEN"
                            Click="CloseButton_Click"
                            Style="{StaticResource CombatButton}"
                            Foreground="#888" BorderBrush="#555"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ COMBAT LOG ═══ -->
        <Border Grid.Row="3" Background="#060a10"
                BorderBrush="#1a2a40" BorderThickness="0,1,0,0">
            <Grid Margin="16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📜 Kampfprotokoll"
                           FontSize="11" FontWeight="Bold" Foreground="#FFD700"
                           Margin="0,0,0,4"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding CombatLog}"
                               Foreground="#aaaaaa" FontSize="11"
                               FontFamily="Consolas" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="Projektarbeit_Dungeon_of_the_Fallen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verlies der Gefallenen"
        Width="1400" Height="900"
        MinWidth="1280" MinHeight="760"
        Background="#0a0a0a" Foreground="#e0e0e0"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.InputBindings>
        <KeyBinding Key="W" Command="{Binding MoveUpCommand}" />
        <KeyBinding Key="A" Command="{Binding MoveLeftCommand}" />
        <KeyBinding Key="S" Command="{Binding MoveDownCommand}" />
        <KeyBinding Key="D" Command="{Binding MoveRightCommand}" />
        <KeyBinding Key="Up" Command="{Binding MoveUpCommand}" />
        <KeyBinding Key="Left" Command="{Binding MoveLeftCommand}" />
        <KeyBinding Key="Down" Command="{Binding MoveDownCommand}" />
        <KeyBinding Key="Right" Command="{Binding MoveRightCommand}" />
        <KeyBinding Key="P" Command="{Binding UsePotionCommand}" />
        <KeyBinding Key="F5" Command="{Binding SaveGameCommand}" />
        <KeyBinding Key="F9" Command="{Binding LoadGameCommand}" />
    </Window.InputBindings>

    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True" Background="#05060a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="⚔️  VERLIES DER GEFALLENEN  ⚔️"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="16,10,16,8"
                   Foreground="#FFD700"
                   HorizontalAlignment="Center" />

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" MinWidth="300" MaxWidth="340" />
            </Grid.ColumnDefinitions>

            <!-- Dungeon / map -->
            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Background="#111111"
                    BorderThickness="2"
                    BorderBrush="#555"
                    ClipToBounds="True">
                <Viewbox Stretch="Uniform"
                         StretchDirection="Both"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         UseLayoutRounding="True"
                         SnapsToDevicePixels="True">
                    <ItemsControl x:Name="DungeonBoard"
                                  ItemsSource="{Binding RenderObjects}"
                                  Width="{Binding RenderSurfaceWidth}"
                                  Height="{Binding RenderSurfaceHeight}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="{Binding Width, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Height="{Binding Height, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Background="#0a0a0a"
                                        ClipToBounds="False"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="UseLayoutRounding" Value="True" />
                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding AssetPath, Converter={StaticResource FallbackImage}}"
                                       Width="{Binding Width}"
                                       Height="{Binding Height}"
                                       Opacity="{Binding Opacity}"
                                       Stretch="Fill"
                                       UseLayoutRounding="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       SnapsToDevicePixels="True"
                                       Margin="0"
                                       ToolTip="{Binding DebugName}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Viewbox>
            </Border>

            <!-- Status panel -->
            <Border Grid.Column="1"
                    Background="#111111"
                    BorderThickness="2"
                    BorderBrush="#555"
                    ClipToBounds="True">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="⚡ SPIELERSTATUS" FontSize="16" FontWeight="Bold"
                                       Foreground="#FFD700" Margin="0,0,0,12" />

                            <!-- HP -->
                            <TextBlock Text="LP" Foreground="#FF6B6B" FontWeight="Bold" Margin="0,4,0,2" />
                            <TextBlock Foreground="#FF8888" FontSize="18" FontWeight="Bold">
                                <Run Text="{Binding PlayerViewModel.HP, Mode=OneWay}" />
                                <Run Text=" / " Foreground="#555" />
                                <Run Text="{Binding PlayerViewModel.MaxHP, Mode=OneWay}" Foreground="#888" />
                            </TextBlock>

                            <Separator Background="#333" Margin="0,10" />

                            <TextBlock Text="STUFE" Foreground="#FFD700" FontWeight="Bold" FontSize="12" Margin="0,2,0,2" />
                            <TextBlock Foreground="#ffffff" FontSize="20" FontWeight="Bold"
                                       Text="{Binding PlayerViewModel.Level}" />

                            <TextBlock Text="KLASSE" Foreground="#AA88FF" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#d6c7ff" FontSize="14" FontWeight="Bold"
                                       Text="{Binding PlayerViewModel.PlayerClassDisplay}" />

                            <TextBlock Text="EBENE" Foreground="#FFA94D" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#ffd3a1" FontSize="14" FontWeight="Bold"
                                       Text="{Binding FloorDisplay}" />

                            <TextBlock Text="BIOM" Foreground="#66CCFF" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#b7e7ff" FontSize="14" FontWeight="Bold"
                                       Text="{Binding BiomeDisplayName}" />

                            <TextBlock Text="ZIEL" Foreground="#7bf0c8" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#c5fff0" FontSize="11" FontWeight="Bold" TextWrapping="Wrap"
                                       Text="{Binding ObjectiveText}" />
                            <TextBlock Foreground="#9ce6d3" FontSize="10" Margin="0,2,0,0"
                                       Text="{Binding ExitStatusText}" />

                            <TextBlock Text="EP" Foreground="#00FF88" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#aaffcc" FontSize="11"
                                       Text="{Binding PlayerViewModel.XP, StringFormat='{}{0} EP'}" />

                            <TextBlock Text="GOLD" Foreground="#FFD700" FontWeight="Bold" FontSize="12" Margin="0,8,0,2" />
                            <TextBlock Foreground="#FFD700" FontSize="14" FontWeight="Bold"
                                       Text="{Binding PlayerViewModel.Gold, StringFormat='{}{0} G'}" />

                            <Separator Background="#333" Margin="0,10" />

                            <TextBlock Text="WERTE" Foreground="#00AAFF" FontWeight="Bold" FontSize="12" Margin="0,2,0,4" />
                            <TextBlock Foreground="#ccddff" FontSize="12"
                                       Text="{Binding PlayerViewModel.Attack, StringFormat='🎯 Angriffswert: +{0}'}" />
                            <TextBlock Foreground="#ccddff" FontSize="12" Margin="0,2"
                                       Text="{Binding PlayerViewModel.ArmorClass, StringFormat='🛡  Rüstungsklasse: {0}'}" />
                            <TextBlock Foreground="#ccddff" FontSize="11" Margin="0,2,0,0"
                                       Text="{Binding PlayerViewModel.WeaponName, StringFormat='⚔  Waffe: {0}'}" />
                            <TextBlock Foreground="#ccddff" FontSize="10"
                                       Text="{Binding PlayerViewModel.WeaponDamage, StringFormat='Schaden: {0}'}" />
                            <TextBlock Foreground="#f3d6ff" FontSize="12" Margin="0,4,0,0"
                                       Text="{Binding PlayerViewModel.SkillName, StringFormat='✨ Fähigkeit: {0}'}" />
                            <TextBlock Foreground="#b8a1c9" FontSize="10" TextWrapping="Wrap"
                                       Text="{Binding PlayerViewModel.SkillDescription}" />

                            <TextBlock Foreground="#88ddff" FontSize="10" Margin="0,2,0,0"
                                       Text="{Binding PlayerViewModel.ArmorSummary, StringFormat='🛡 {0}'}" />

                            <Separator Background="#333" Margin="0,10" />

                            <!-- Tränke -->
                            <TextBlock Text="TRÄNKE" Foreground="#FF88FF" FontWeight="Bold" FontSize="12" Margin="0,2,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="#FF88FF" FontSize="18" FontWeight="Bold"
                                           Text="{Binding PlayerViewModel.PotionCount}" VerticalAlignment="Center" />
                                <Button Content="Trank benutzen [P]" Command="{Binding UsePotionCommand}"
                                        FontSize="11" Foreground="#FF88FF" Background="#2a1a2a"
                                        BorderBrush="#FF88FF" BorderThickness="1"
                                        Padding="6,2" Margin="8,0,0,0" Cursor="Hand" />
                            </StackPanel>

                            <Separator Background="#333" Margin="0,12" />

                            <TextBlock Text="LAUFSTATUS" Foreground="#888" FontWeight="Bold" FontSize="11" Margin="0,0,0,4" />
                            <TextBlock Foreground="#cccccc" FontSize="10" TextWrapping="Wrap"
                                       Text="{Binding RunStatusText}" />
                            <TextBlock Text="PHASE" Foreground="#888" FontWeight="Bold" FontSize="11" Margin="0,8,0,4" />
                            <TextBlock Foreground="#9cc8ff" FontSize="11" FontWeight="Bold"
                                       Text="{Binding GamePhaseText}" />
                            <TextBlock Foreground="#9cc8ff" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding DungeonSystemsText}" />

                            <StackPanel Margin="0,10,0,0" Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}">
                                <Button Content="{Binding ContinueButtonText}" Command="{Binding ContinueCommand}"
                                        FontSize="11" Foreground="#aaffcc" Background="#12261a"
                                        BorderBrush="#66cc88" BorderThickness="1"
                                        Padding="6,4" Cursor="Hand" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <Separator Background="#333" Margin="0,12" />

                            <!-- Legende -->
                            <TextBlock Text="LEGENDE" Foreground="#888" FontWeight="Bold" FontSize="11" Margin="0,0,0,4" />
                            <StackPanel>
                                <TextBlock FontSize="10" Foreground="#aaa">
                                    <Run Foreground="#00AA00">P</Run><Run> = Spieler    </Run>
                                    <Run Foreground="#ff4444">E</Run><Run> = Feind    </Run>
                                    <Run Foreground="#c7a6ff">N</Run><Run> = NPC</Run>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="#aaa">
                                    <Run Foreground="#FFD700">E</Run><Run> = Ausgang    </Run>
                                    <Run Foreground="#88aaff">I</Run><Run> = Item    </Run>
                                    <Run Foreground="#7b5a30">D</Run><Run> = Tür</Run>
                                </TextBlock>
                                <TextBlock FontSize="10" Foreground="#aaa">
                                    <Run Foreground="#0088FF">~</Run><Run> = Heilraum    </Run>
                                    <Run Foreground="#AA0000">!</Run><Run> = Falle    </Run>
                                    <Run Foreground="#5a4fcf">?</Run><Run> = Rätsel    </Run>
                                    <Run Foreground="#346b7a">K</Run><Run> = Schlüssel</Run>
                                </TextBlock>
                            </StackPanel>

                            <Separator Background="#333" Margin="0,12" />

                            <!-- Save/Load -->
                            <TextBlock Text="SPIEL SPEICHERN / LADEN" Foreground="#888" FontWeight="Bold" FontSize="11" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Spiel speichern [F5]" Command="{Binding SaveGameCommand}"
                                        FontSize="11" Foreground="#88FF88" Background="#1a2a1a"
                                        BorderBrush="#88FF88" BorderThickness="1"
                                        Padding="6,3" Cursor="Hand" />
                                <Button Content="Spiel laden [F9]" Command="{Binding LoadGameCommand}"
                                        FontSize="11" Foreground="#8888FF" Background="#1a1a2a"
                                        BorderBrush="#8888FF" BorderThickness="1"
                                        Padding="6,3" Margin="6,0,0,0" Cursor="Hand" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Navigation buttons stay visible -->
                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <Separator Background="#333" Margin="0,0,0,10" />
                        <TextBlock Text="MENÜ / ABENTEUER" Foreground="#888" FontWeight="Bold" FontSize="11" Margin="0,0,0,6" />
                        <Button Content="💾  Speichern &amp; Hauptmenü" Command="{Binding SaveAndReturnToMenuCommand}"
                                FontSize="11" Foreground="#FFD700" Background="#1a1a0a"
                                BorderBrush="#FFD700" BorderThickness="1"
                                Padding="6,4" Cursor="Hand" Margin="0,0,0,5" HorizontalAlignment="Stretch" />
                        <Button Content="🏠  Hauptmenü (ohne Speichern)" Command="{Binding ReturnToMenuCommand}"
                                FontSize="11" Foreground="#AAAAAA" Background="#111111"
                                BorderBrush="#555555" BorderThickness="1"
                                Padding="6,4" Cursor="Hand" Margin="0,0,0,5" HorizontalAlignment="Stretch" />
                        <Button Content="✕  Abenteuer abbrechen" Command="{Binding AbandonRunCommand}"
                                FontSize="11" Foreground="#FF6666" Background="#1a0a0a"
                                BorderBrush="#AA3333" BorderThickness="1"
                                Padding="6,4" Cursor="Hand" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Combat log -->
        <Border Grid.Row="2"
                Margin="10,10,10,10"
                Height="150"
                MinHeight="130"
                MaxHeight="180"
                Background="#111111"
                BorderThickness="2"
                BorderBrush="#555">
            <Grid Margin="10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📜  KAMPFPROTOKOLL"
                           FontSize="13" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,4" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding CombatLog}" Foreground="#cccccc"
                               TextWrapping="Wrap" FontSize="11" FontFamily="Consolas" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Game Over Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Background="#000000" Opacity="0.85"
              Visibility="{Binding IsGameOver, Converter={StaticResource BoolToVis}}">
            <Border Background="#1a1a1a" BorderThickness="3" BorderBrush="#FFD700" Margin="200,150">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <TextBlock Text="{Binding IsVictory, Converter={StaticResource VictoryText}}"
                               FontSize="42" FontWeight="Bold" Foreground="#FFD700"
                               TextAlignment="Center" Margin="0,0,0,20" />
                    <TextBlock Text="{Binding PlayerViewModel.StatusText}"
                               Foreground="#cccccc" FontSize="13" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,20" />
                    <Button Command="{Binding RestartGameCommand}"
                            FontSize="16" Foreground="#FFD700" Background="#2a2a2a"
                            BorderBrush="#FFD700" BorderThickness="2"
                            Content="Neu starten" Padding="16,8" Cursor="Hand" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Projektarbeit_Dungeon_of_the_Fallen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projektarbeit_Dungeon_of_the_Fallen"
        mc:Ignorable="d"
        Title="Dungeon of the Fallen" Height="900" Width="1400"
        Background="#0a0a0a"
        Foreground="#e0e0e0">
    <Grid>
        <!-- Main Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" 
                   Text="⚔️ DUNGEON OF THE FALLEN ⚔️" 
                   FontSize="24" FontWeight="Bold" Margin="20"
                   Foreground="#FFD700" HorizontalAlignment="Center" />

        <!-- Dungeon Grid (Links) -->
        <Border Grid.Column="0" Grid.Row="1" Margin="10" Background="#1a1a1a" BorderThickness="2" BorderBrush="#444">
            <ItemsControl ItemsSource="{Binding Tiles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding DungeonWidth}" Rows="{Binding DungeonHeight}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" BorderBrush="#333333" 
                                Background="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}">
                            <TextBlock Text="{Binding DisplayText}" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#ffffff" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Player Status (Rechts) -->
        <StackPanel Grid.Column="1" Grid.Row="1" Background="#1a1a1a" Margin="15"
                    VerticalAlignment="Top">
            <TextBlock Text="⚡ PLAYER STATUS" FontSize="18" FontWeight="Bold" 
                       Foreground="#FFD700" Margin="0,0,0,15" />
            
            <TextBlock Text="{Binding PlayerViewModel.StatusText}" 
                       TextWrapping="Wrap" Foreground="#e0e0e0" 
                       FontSize="14" Margin="0,5" />
            
            <TextBlock Text="HP:" Foreground="#FF6B6B" FontWeight="Bold" Margin="0,15,0,5" />
            <TextBlock Text="{Binding PlayerViewModel.HP, StringFormat='Current: {0}'}" 
                       Foreground="#e0e0e0" Margin="0,2" />
            <TextBlock Text="{Binding PlayerViewModel.MaxHP, StringFormat='Max: {0}'}" 
                       Foreground="#e0e0e0" Margin="0,2" />
            
            <TextBlock Text="LEVEL:" Foreground="#FFD700" FontWeight="Bold" Margin="0,15,0,5" />
            <TextBlock Text="{Binding PlayerViewModel.Level}" 
                       Foreground="#e0e0e0" FontSize="16" />
            
            <TextBlock Text="XP:" Foreground="#00FF00" FontWeight="Bold" Margin="0,15,0,5" />
            <TextBlock Text="{Binding PlayerViewModel.XP}" 
                       Foreground="#e0e0e0" />
            
            <TextBlock Text="GOLD:" Foreground="#FFD700" FontWeight="Bold" Margin="0,15,0,5" />
            <TextBlock Text="{Binding PlayerViewModel.Gold}" 
                       Foreground="#FFD700" FontSize="14" />
            
            <TextBlock Text="ATK / DEF:" Foreground="#00AAFF" FontWeight="Bold" Margin="0,15,0,5" />
            <TextBlock Text="{Binding PlayerViewModel.Attack, StringFormat='Attack: {0}'}" 
                       Foreground="#e0e0e0" Margin="0,2" />
            <TextBlock Text="{Binding PlayerViewModel.Defense, StringFormat='Defense: {0}'}" 
                       Foreground="#e0e0e0" Margin="0,2" />
        </StackPanel>

        <!-- Combat Log (Unten) -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="10" 
                Background="#1a1a1a" BorderThickness="2" BorderBrush="#444">
            <StackPanel>
                <TextBlock Text="📜 COMBAT LOG" FontSize="14" FontWeight="Bold" 
                           Foreground="#FFD700" Margin="0,0,0,5" />
                <TextBlock Text="Game started. Ready for adventure!" 
                           Foreground="#e0e0e0" TextWrapping="Wrap" 
                           FontSize="11" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="Projektarbeit_Dungeon_of_the_Fallen.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dungeon of the Fallen" Height="640" Width="880"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Width" Value="320"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#FFD700"/>
            <Setter Property="Background" Value="#0e1820"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1c2a3a"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFE566"/>
                                <Setter Property="Foreground" Value="#FFE566"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2a3a4a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#03060c" Offset="0"/>
                <GradientStop Color="#060c18" Offset="0.5"/>
                <GradientStop Color="#030609" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <!-- Outer border glow -->
        <Border BorderBrush="#1a2a3a" BorderThickness="1" CornerRadius="8">

            <Grid>
                <!-- Background image -->
                <Image Source="/Assets/Backgrounds/background_menu_dungeon_01.png"
                       Stretch="UniformToFill" Opacity="0.22"/>

                <!-- Decorative top/bottom bars -->
                <Border Height="3" VerticalAlignment="Top" CornerRadius="8,8,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FFD700" Offset="0.3"/>
                            <GradientStop Color="#FFD700" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Height="3" VerticalAlignment="Bottom" CornerRadius="0,0,8,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FFD700" Offset="0.3"/>
                            <GradientStop Color="#FFD700" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Drag handle (window can be dragged) -->
                <Rectangle Height="640" MouseLeftButtonDown="Window_MouseLeftButtonDown"
                           Fill="Transparent"/>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">

                    <!-- Decorative top line -->
                    <TextBlock Text="─── ⚔ ───"
                               FontSize="20" Foreground="#555566"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               FontFamily="Consolas"/>

                    <!-- Main title -->
                    <TextBlock Text="DUNGEON"
                               FontSize="62" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center" Foreground="#FFD700"
                               Margin="0,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="22"
                                              Opacity="0.55" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="OF THE FALLEN"
                               FontSize="32" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center" Foreground="#CC9900"
                               Margin="0,-8,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="14"
                                              Opacity="0.4" ShadowDepth="0"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Subtitle -->
                    <TextBlock Text="Eine Geschichte von Ruhm und Verderben"
                               FontSize="14" FontStyle="Italic"
                               Foreground="#4a5a6a" FontFamily="Consolas"
                               HorizontalAlignment="Center" Margin="0,12,0,44"/>

                    <!-- Buttons -->
                    <Button x:Name="NewGameButton" Content="▶   NEUES SPIEL"
                            Style="{StaticResource MenuButton}"
                            Click="NewGame_Click"
                            Margin="0,0,0,14"/>

                    <TextBlock Text="KLASSE"
                               FontSize="12" FontWeight="Bold" Foreground="#6f86a0"
                               HorizontalAlignment="Center" Margin="0,4,0,8"
                               FontFamily="Consolas"/>

                    <ComboBox x:Name="ClassSelectionComboBox"
                              Width="320" Height="34"
                              Margin="0,0,0,18"
                              Background="#0e1820"
                              Foreground="#FFD700"
                              BorderBrush="#FFD700"
                              HorizontalContentAlignment="Center"
                              FontFamily="Consolas"
                              FontSize="14"/>

                    <Button x:Name="LoadGameButton" Content="📂   LADEN"
                            Style="{StaticResource MenuButton}"
                            Click="LoadGame_Click"
                            Margin="0,0,0,14"/>

                    <Button Content="✕   BEENDEN"
                            Style="{StaticResource MenuButton}"
                            Click="Exit_Click"
                            Foreground="#AA7777" BorderBrush="#AA7777"
                            Margin="0,0,0,0"/>

                    <!-- Bottom info -->
                    <TextBlock Text="─── ⚔ ───"
                               FontSize="20" Foreground="#333344"
                               HorizontalAlignment="Center" Margin="0,40,0,0"
                               FontFamily="Consolas"/>

                    <TextBlock Text="WASD / Pfeile = Bewegen  |  P = Trank  |  F5 = Speichern  |  F9 = Laden"
                               FontSize="10" Foreground="#2a3a4a"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>

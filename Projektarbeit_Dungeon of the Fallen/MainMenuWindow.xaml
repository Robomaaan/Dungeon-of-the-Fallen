<Window x:Class="Projektarbeit_Dungeon_of_the_Fallen.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dungeon of the Fallen" Height="660" Width="900"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Border CornerRadius="8" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#03060c" Offset="0"/>
                <GradientStop Color="#060c18" Offset="0.5"/>
                <GradientStop Color="#030609" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border BorderBrush="#1a2a3a" BorderThickness="1" CornerRadius="8">
            <Grid>

                <!-- Hintergrundgrafik (kein Absturz wenn fehlt) -->
                <Image Source="/Assets/Backgrounds/background_menu_dungeon_01.png"
                       Stretch="UniformToFill" Opacity="0.22"/>

                <!-- Animierte Nebelschichten (werden in Code-Behind eingeblendet) -->
                <Image x:Name="FogLayer1"
                       Source="/Assets/Backgrounds/background_menu_dungeon_01.png"
                       Stretch="UniformToFill" Opacity="0"/>
                <Image x:Name="FogLayer2"
                       Source="/Assets/Backgrounds/background_menu_dungeon_01.png"
                       Stretch="UniformToFill" Opacity="0"/>

                <!-- Goldlinie oben -->
                <Border Height="3" VerticalAlignment="Top" CornerRadius="8,8,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FFD700"     Offset="0.3"/>
                            <GradientStop Color="#FFD700"     Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Goldlinie unten -->
                <Border Height="3" VerticalAlignment="Bottom" CornerRadius="0,0,8,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#FFD700"     Offset="0.3"/>
                            <GradientStop Color="#FFD700"     Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Drag-Handle -->
                <Rectangle Height="660" Fill="Transparent"
                           MouseLeftButtonDown="Window_MouseLeftButtonDown"/>

                <!-- Hauptinhalt -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center" Width="520">

                    <!-- Dekor oben -->
                    <TextBlock Text="─── ⚔ ───"
                               FontSize="22" Foreground="#333344"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,0,0,18"/>

                    <!-- Logo (optional, Fallback transparent) -->
                    <Image Source="/Assets/Backgrounds/background_menu_dungeon_01.png"
                           Height="72" HorizontalAlignment="Center"
                           Margin="0,0,0,8" Stretch="Uniform"/>

                    <!-- Titel -->
                    <TextBlock Text="DUNGEON"
                               Style="{StaticResource MenuTitleStyle}"/>
                    <TextBlock Text="OF THE FALLEN"
                               Style="{StaticResource MenuSubtitleStyle}"
                               Margin="0,-8,0,0"/>

                    <!-- Tagline -->
                    <TextBlock Text="Eine Geschichte von Ruhm und Verderben"
                               FontSize="13" FontStyle="Italic"
                               Foreground="#3a4a5a" FontFamily="Consolas"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>

                    <!-- Goldtrennlinie -->
                    <Border Style="{StaticResource GoldSeparatorStyle}" Margin="0,20"/>

                    <!-- Menü-Panel -->
                    <Border Style="{StaticResource DarkPanelStyle}" Padding="40,32">
                        <StackPanel>

                            <Button Content="▶   NEUES SPIEL"
                                    Style="{StaticResource MenuButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Click="NewGame_Click"
                                    Margin="0,0,0,14"/>

                            <Button x:Name="LoadGameButton"
                                    Content="📂   LADEN"
                                    Style="{StaticResource MenuButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Click="LoadGame_Click"
                                    Margin="0,0,0,14"/>

                            <Border Height="1" Margin="60,6,60,14"
                                    Background="#1e2a38"/>

                            <Button Content="✕   BEENDEN"
                                    Style="{StaticResource ExitButtonStyle}"
                                    HorizontalAlignment="Center"
                                    Click="Exit_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Dekor unten + Steuerhinweise -->
                    <TextBlock Text="─── ⚔ ───"
                               FontSize="22" Foreground="#222233"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,22,0,0"/>
                    <TextBlock Text="WASD / Pfeile = Bewegen  |  P = Trank  |  F5 = Speichern  |  F9 = Laden"
                               FontSize="10" Foreground="#1e2a38"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas" Margin="0,8,0,0"/>
                </StackPanel>

            </Grid>
        </Border>
    </Border>
</Window>
